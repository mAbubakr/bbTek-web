---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToAction from "@/partials/CallToAction.astro";
import Testimonial from "@/partials/Testimonial.astro";

const homepage = await getListPage("homepage", "-index");
const call_to_action = await getListPage("ctaSection", "call-to-action");
const testimonial = await getListPage("testimonialSection", "testimonial");

const { banner, features, social_proof, benefits, projects } = homepage.data;

const allProjects = await getSinglePage("projects");
const featuredProjects = allProjects
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Base>
  <!-- Hero Section -->
  <section
    id="hero"
    class="relative min-h-[90vh] flex items-center justify-center overflow-hidden"
  >
    {/* Background image */}
    {banner.image && (
      <div class="absolute inset-0 z-0">
        <ImageMod
          src={banner.image}
          height={1080}
          width={1920}
          alt=""
          format="webp"
          class="w-full h-full object-cover object-center"
        />
        {/* Dark overlay so text is legible */}
        <div class="absolute inset-0 bg-black/60"></div>
      </div>
    )}

    {/* Content */}
    <div class="container relative z-10 py-32">
      <div class="row justify-center">
        <div class="lg:col-8 md:col-10 text-center">
          <h1
            set:html={markdownify(banner.title)}
            class="mb-6 text-5xl lg:text-7xl font-bold text-white leading-tight"
          />
          <p
            set:html={markdownify(banner.content)}
            class="mb-10 text-xl text-white/80 max-w-2xl mx-auto leading-relaxed"
          />
          {banner.button.enable && (
            <a
              class="btn btn-primary px-10 py-4 text-lg font-semibold shadow-lg"
              href={banner.button.link}
              target={banner.button.link.startsWith("http") ? "_blank" : "_self"}
              rel="noopener"
            >
              {banner.button.label}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
  <!-- /Hero Section -->

  <!-- Features -->
  <section id="features" class="section py-20">
    <div class="container">
      <div class="row">
        {features.map((feature) => (
          <div class="md:col-6 lg:col-3 mb-8">
            <div class="bg-white dark:bg-darkmode-light p-8 rounded-xl shadow-sm border border-gray-100 dark:border-darkmode-border hover:shadow-md transition-shadow duration-300 h-full">
              <div class="text-4xl mb-4">{feature.icon}</div>
              <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-darkmode-text-dark">{feature.title}</h3>
              <p class="text-gray-600 dark:text-darkmode-text mb-6 leading-relaxed">{feature.content}</p>
              {feature.button.enable && (
                <a class="text-blue-600 dark:text-darkmode-primary font-medium hover:text-blue-800 dark:hover:text-darkmode-dark transition-colors" href={feature.button.link}>
                  {feature.button.label} →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- /Features -->

  <!-- Social Proof -->
  {social_proof && (
    <section id="testimonials" class="section py-16 bg-gray-50 dark:bg-darkmode-light">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-darkmode-text-dark mb-4">{social_proof.title}</h2>
          <div class="text-6xl font-bold text-blue-600 dark:text-darkmode-primary mb-2">{social_proof.count}</div>
          <div class="text-xl text-gray-600 dark:text-darkmode-text">{social_proof.label}</div>
        </div>
        <div class="row">
          {social_proof.testimonials.map((testimonial) => (
            <div class="md:col-4 mb-8">
              <div class="bg-white dark:bg-darkmode-body p-6 rounded-lg shadow-sm border border-gray-100 dark:border-darkmode-border">
                <div class="text-yellow-400 text-xl mb-3">★★★★★</div>
                <p class="text-gray-700 dark:text-darkmode-text mb-4 italic">"{testimonial.content}"</p>
                <div class="font-semibold text-gray-900 dark:text-darkmode-text-dark">{testimonial.author}</div>
                <div class="text-sm text-gray-600 dark:text-darkmode-text">{testimonial.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
  <!-- /Social Proof -->

  <!-- Benefits -->
  {benefits && (
    <section id="benefits" class="section py-20">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-darkmode-text-dark mb-4">{benefits.title}</h2>
        </div>
        <div class="row">
          {benefits.items.map((benefit) => (
            <div class="md:col-6 lg:col-4 mb-8">
              <div class="text-center">
                <div class="text-5xl mb-4">{benefit.icon}</div>
                <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-darkmode-text-dark">{benefit.title}</h3>
                <p class="text-gray-600 dark:text-darkmode-text leading-relaxed">{benefit.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
  <!-- /Benefits -->

  <!-- Projects -->
  {projects && featuredProjects.length > 0 && (
    <section id="projects" class="section py-20 bg-gray-50 dark:bg-darkmode-light">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-darkmode-text-dark mb-4">{projects.title}</h2>
          <p class="text-xl text-gray-600 dark:text-darkmode-text">{projects.subtitle}</p>
        </div>
        <div class="row">
          {featuredProjects.map((project) => (
            <div class="md:col-6 lg:col-4 mb-8">
              <div class="bg-white dark:bg-darkmode-body rounded-xl shadow-sm border border-gray-100 dark:border-darkmode-border overflow-hidden hover:shadow-lg transition-shadow duration-300 h-full flex flex-col">
                <div class="aspect-video bg-gray-200 dark:bg-darkmode-body relative overflow-hidden">
                  {project.data.image && (
                    <ImageMod
                      src={project.data.image}
                      height={240}
                      width={400}
                      alt={project.data.title}
                      format="webp"
                      class="w-full h-full object-cover"
                    />
                  )}
                </div>
                <div class="p-6 flex flex-col flex-1">
                  <div class="flex flex-wrap gap-2 mb-3">
                    {project.data.categories.map((category) => (
                      <span class="px-2 py-1 bg-blue-100 dark:bg-darkmode-border text-blue-800 dark:text-darkmode-primary text-xs font-medium rounded-full">
                        {category}
                      </span>
                    ))}
                  </div>
                  <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-darkmode-text-dark">{project.data.title}</h3>
                  <p class="text-gray-600 dark:text-darkmode-text mb-4 leading-relaxed flex-1">{project.data.description}</p>
                  <a href={`/projects/${project.id}`} class="text-blue-600 dark:text-darkmode-primary font-medium hover:text-blue-800 dark:hover:text-darkmode-dark transition-colors">
                    View Details →
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="text-center mt-12 flex flex-wrap gap-4 justify-center">
          <a href="/projects" class="btn btn-outline-primary px-8 py-3 text-lg font-semibold">
            View All Projects
          </a>
          <a href="/contact" class="btn btn-primary px-8 py-3 text-lg font-semibold">
            Start Your Project
          </a>
        </div>
      </div>
    </section>
  )}
  <!-- /Projects -->

  <CallToAction call_to_action={call_to_action} id="contact" />
</Base>
