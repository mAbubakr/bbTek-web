---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

// Props interface for the component
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: "eager" | "lazy" | null | undefined;
  decoding?: "async" | "auto" | "sync" | null | undefined;
  format?: "auto" | "avif" | "jpeg" | "png" | "svg" | "webp";
  class?: string;
  style?: any;
}

// Destructuring Astro.props to get the component's props
let { src, alt, width, height, loading, decoding, class: className, format, style } = Astro.props;

// Check if the source is an SVG
const isSvg = src.toLowerCase().endsWith('.svg');

// For SVGs, use the public path directly
const publicSrc = src.startsWith('/') ? src : `/${src}`;

// For non-SVG images, use the glob pattern
const originalSrc = `/public${src}`;
const images = import.meta.glob("/public/images/**/*.{jpeg,jpg,png,gif,svg}");
const isValidPath = isSvg ? true : (images[originalSrc] ? true : false);

// Log a warning message in red if the image is not found
!isValidPath &&
  !isSvg &&
  console.error(`\x1b[31mImage not found - ${originalSrc}.\x1b[0m Make sure the image is in the /public/images folder.`);
---

{
  isSvg ? (
    <img
      src={publicSrc}
      alt={alt}
      width={width}
      height={height}
      loading={loading || "lazy"}
      decoding={decoding || "async"}
      class={className}
      style={style}
    />
  ) : isValidPath ? (
    <Image
      src={images[originalSrc]() as Promise<{ default: ImageMetadata }>}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      class={className}
      format={format}
      style={style}
    />
  ) : null
}
