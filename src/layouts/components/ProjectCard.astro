---
import config from "@/config/config.json";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import ImageMod from "./ImageMod.astro";

const {
  summary_length,
}: { summary_length: number } = config.settings;
const { data } = Astro.props;
const { title, image, date, categories, tags } = data.data;
---

<div class="bg-body dark:bg-darkmode-body">
  {
    image && (
      <ImageMod
        class="mb-6 w-full rounded"
        src={image}
        alt={title}
        width={445}
        height={230}
        format="webp"
      />
    )
  }
  <h4 class="mb-3">
    <a href={`/projects/${data.id}`}>
      {title}
    </a>
  </h4>
  <ul class="mb-4">
    <li class="mr-4 inline-block">
      <span class="icon-folder mr-2 -mt-1 inline-block"></span>
      {
        categories?.map((category: string, index: number) => (
          category && (
            <a href={`/categories/${slugify(category)}`}>
              {humanize(category)}
              {index !== categories.length - 1 && ","}
            </a>
          )
        ))
      }
    </li>
    {date && (
      <li class="inline-block">
        <span class="icon-calendar mr-2 -mt-1 inline-block"></span>
        {dateFormat(date)}
      </li>
    )}
  </ul>
  <p class="mb-6">{plainify(data.body?.slice(0, Number(summary_length)))}</p>
  <a class="btn btn-outline-primary btn-sm" href={`/projects/${data.id}`}>
    View Project
  </a>
</div>